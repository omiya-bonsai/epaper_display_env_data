# =========================================================================
# e-Paper Display System Configuration (.env.sample)
# =========================================================================
#
# このファイルをコピーして .env を作成してください:
#
#   cp .env.sample .env
#
# 必要に応じて MQTT トピックやパスを変更します
# =========================================================================


# =========================================================================
# MQTT CONNECTION SETTINGS
# =========================================================================

MQTT_BROKER_IP_ADDRESS="192.168.3.82"
MQTT_BROKER_PORT=1883
MQTT_KEEPALIVE=60

MQTT_CLIENT_ID="epaper_display_subscriber_zero2w"


# =========================================================================
# MQTT TOPICS
# =========================================================================

MQTT_TOPIC_QZSS_CPU_TEMP="raspberry/qzss/temperature"
MQTT_TOPIC_PI_CPU_TEMP="raspberry/temperature"

MQTT_TOPIC_ENV4="env4"

MQTT_TOPIC_CO2_DATA="co2_data"
MQTT_TOPIC_SENSOR_DATA="sensor_data"

# Optional:
# MQTT_TOPIC_RAIN="home/weather/rain_sensor"


# =========================================================================
# FILE PATH SETTINGS
# =========================================================================

BASE_DIRECTORY="/home/bonsai/python3/e-ink/data"

DISPLAY_FONT_FILE_PATH="/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"


# =========================================================================
# DISPLAY HARDWARE SETTINGS
# =========================================================================

EPAPER_DISPLAY_TYPE="epd2in13_V4"

DISPLAY_FONT_SIZE_PIXELS=16


# =========================================================================
# DISPLAY UPDATE POLICY
# =========================================================================
#
# 更新周期の関係:
#
# partial refresh 間隔
#   = DISPLAY_UPDATE_INTERVAL_SECONDS
#
# full refresh 間隔
#   = DISPLAY_UPDATE_INTERVAL_SECONDS
#     × PARTIAL_REFRESH_EVERY_N_UPDATES
#
# 例:
# partial refresh = 30秒
# full refresh    = 180秒（3分）
#

DISPLAY_UPDATE_INTERVAL_SECONDS=30

ENABLE_PARTIAL_REFRESH=True

PARTIAL_REFRESH_EVERY_N_UPDATES=6

SKIP_UPDATE_IF_IMAGE_UNCHANGED=True


# =========================================================================
# DATA VALIDITY THRESHOLDS
# =========================================================================

DATA_STALENESS_THRESHOLD_SECONDS=800

# Optional:
# NO_CHANGE_ERROR_THRESHOLD_SECONDS=960


# =========================================================================
# OPTIONAL SERVICE MONITORING
# =========================================================================

ENABLE_SERVICE_MONITORING=false

DUMP1090_SERVICE_NAME="dump1090-fa.service"


# =========================================================================
# OPTIONAL DISPLAY LABEL
# =========================================================================

# ADS_LABEL="ADS"
